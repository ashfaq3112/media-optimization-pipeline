# MongoDB connection string for optimizer
MONGO_URI=mongodb://mongo:27017/mediaopt

# GitHub token used by optimizer to commit and comment back to the PR
GITHUB_TOKEN=your_github_token_here

# Repository metadata injected by GitHub Actions
PR_NUMBER=123
BRANCH_NAME=feature/my-branch
REPO_NAME=owner/repo
WORKSPACE_PATH=/workspace
CHANGED_FILES_PATH=/workspace/changed-files.txt
CHANGED_IMAGES_PATH=/workspace/changed-images.json
